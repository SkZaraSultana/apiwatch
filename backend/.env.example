PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/apiwatch
CLIENT_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5000

JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@apiwatch.dev

MONITOR_TICK_SECONDS=30

ALERT_LATENCY_THRESHOLD_MS=3000
ALERT_LATENCY_COOLDOWN_MINUTES=60

SECURITY_EVENT_COOLDOWN_MINUTES=30
SECURITY_ANALYSIS_WINDOW=10
